# API mode: auto | local | railway
VITE_API_MODE=auto

# Used when mode is local (or auto + localhost)
# Quick switch between local ports (3001 or 8080)
VITE_API_LOCAL_PORT=3001
# Optional override, if set it takes priority over VITE_API_LOCAL_PORT
VITE_API_LOCAL_URL=http://localhost:3001

# Used when mode is railway (or auto + non-localhost)
VITE_API_RAILWAY_URL=https://truyentranh-backend-production.up.railway.app

# Optional hard override (highest priority)
# VITE_API_BASE_URL=https://your-backend.up.railway.app